{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kuriume",
  "version": "0.1.0",
  "identifier": "com.twac.kuriume",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "kuriume",
        "width": 1280,
        "height": 960,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [
        "libs/macos/libSvtAv1Enc.4.0.1.dylib",
        "libs/macos/libarchive.13.dylib",
        "libs/macos/libass.9.dylib",
        "libs/macos/libavcodec.62.11.100.dylib",
        "libs/macos/libavdevice.62.1.100.dylib",
        "libs/macos/libavfilter.11.4.100.dylib",
        "libs/macos/libavformat.62.3.100.dylib",
        "libs/macos/libavutil.60.8.100.dylib",
        "libs/macos/libb2.1.dylib",
        "libs/macos/libbluray.3.dylib",
        "libs/macos/libcrypto.3.dylib",
        "libs/macos/libdav1d.7.dylib",
        "libs/macos/libfontconfig.1.dylib",
        "libs/macos/libfreetype.6.dylib",
        "libs/macos/libfribidi.0.dylib",
        "libs/macos/libglib-2.0.0.dylib",
        "libs/macos/libgraphite2.3.2.1.dylib",
        "libs/macos/libharfbuzz.0.dylib",
        "libs/macos/libintl.8.dylib",
        "libs/macos/libjpeg.8.3.2.dylib",
        "libs/macos/liblcms2.2.dylib",
        "libs/macos/libluajit-5.1.2.1.1772619647.dylib",
        "libs/macos/liblz4.1.10.0.dylib",
        "libs/macos/liblzma.5.dylib",
        "libs/macos/libmp3lame.0.dylib",
        "libs/macos/libmpv.2.dylib",
        "libs/macos/libmujs.dylib",
        "libs/macos/libopus.0.dylib",
        "libs/macos/libpcre2-8.0.dylib",
        "libs/macos/libplacebo.360.dylib",
        "libs/macos/libpng16.16.dylib",
        "libs/macos/librubberband.3.dylib",
        "libs/macos/libsamplerate.0.2.2.dylib",
        "libs/macos/libshaderc_shared.1.dylib",
        "libs/macos/libssl.3.dylib",
        "libs/macos/libswresample.6.1.100.dylib",
        "libs/macos/libswscale.9.1.100.dylib",
        "libs/macos/libuchardet.0.0.8.dylib",
        "libs/macos/libudfread.3.dylib",
        "libs/macos/libunibreak.6.dylib",
        "libs/macos/libvpx.12.dylib",
        "libs/macos/libvulkan.1.4.341.dylib",
        "libs/macos/libx264.165.dylib",
        "libs/macos/libx265.215.dylib",
        "libs/macos/libzimg.2.dylib",
        "libs/macos/libzstd.1.5.7.dylib"
      ]
